# ============================================================================
# SOLAR INVERTER PLATFORM - ENVIRONMENT VARIABLES
# ============================================================================

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Growatt API Configuration
GROWATT_BASE_URL=https://server.growatt.com
GROWATT_EMAIL=your-growatt-email
GROWATT_PASSWORD=your-growatt-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring Jobs
MONITOR_INTERVAL_MINUTES=5
SYNC_SITES_INTERVAL_HOURS=24
ALERT_CHECK_INTERVAL_MINUTES=3

# Alert Thresholds
OFFLINE_THRESHOLD_MINUTES=10
BATTERY_LOW_THRESHOLD=20
TEMPERATURE_HIGH_THRESHOLD=65

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@solarplatform.com

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
