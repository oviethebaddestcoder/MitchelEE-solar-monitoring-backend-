{
  "name": "solar-inverter-platform",
  "version": "1.0.0",
  "description": "Enterprise Solar Inverter Monitoring Platform with Growatt Integration",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "jobs:monitor": "tsx src/jobs/monitor.job.ts",
    "worker": "tsx src/workers/index.ts",
    "queue:monitor": "tsx src/scripts/queue-monitor.ts",
    "workers:status": "tsx src/scripts/worker-status.ts",
    "queue:retry": "tsx src/scripts/retry-failed-jobs.ts",
    "db:cleanup": "tsx src/scripts/cleanup-old-metrics.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external"
  },
  "keywords": [
    "solar",
    "inverter",
    "monitoring",
    "growatt",
    "iot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.67.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "growatt": "^0.7.7",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "opossum": "^9.0.0",
    "rate-limiter-flexible": "^5.0.5",
    "resend": "^6.12.0",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=9.0.0"
  }
}
